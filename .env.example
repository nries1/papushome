# DATABASE_URL=file:./dev.db
# TEST_DATABASE_URL=file:./.redwood/test.db
# PRISMA_HIDE_UPDATE_MESSAGE=true
# LOG_LEVEL=trace

# --- Database (required) ---
# Backs the RedwoodJS/Prisma app via the `redwood-db` service. Only matter on
# FIRST startup of that container — Postgres bakes them into the data volume
# then; changing them later won't fix a mismatch against existing data.
# REDWOOD_POSTGRES_USER=
# REDWOOD_POSTGRES_PASSWORD=
# REDWOOD_POSTGRES_DB=
# DATABASE_URL=postgresql://user:pass@localhost:5433/dbname

# Legacy pre-Redwood Postgres (`db` service) — not started by default, kept
# only as a rollback safety net. Only needed if you explicitly start it.
# POSTGRES_USER=
# POSTGRES_PASSWORD=
# POSTGRES_DB=

# --- Core app config (required) ---
# Auth token for the physical e-ink display board (bypasses Cloudflare
# Access). Must match the DISPLAY_TOKEN compiled into the display's
# hardware/rgb-display firmware. Generate with: openssl rand -hex 24
# DISPLAY_TOKEN=

# Comma-separated list of emails that get the "admin" role once authenticated
# via Cloudflare Access (gates things like waterPlants/canWater/device admin).
# ADMIN_EMAILS=you@example.com,partner@example.com

# --- Hardware / MQTT ---
# Defaults to the compose network address of the mqtt-broker service —
# only override if you're running the broker elsewhere.
# MQTT_BROKER_URL=mqtt://mqtt-broker:1883

# --- Media / photo storage ---
# Both have working defaults; override only if you changed the storage layout.
# UPLOAD_PATH=/app/secure-private-storage/family
# MEDIA_URL_PREFIX=/api/media

# --- Dashboard cosmetics (optional, have defaults) ---
# LOCATION_LABEL=Brooklyn, NY
# AI_PLACEHOLDER=RTX 2070 Online. How can I help?

# --- Weather (optional — defaults to Brooklyn, NY) ---
# WEATHER_LAT=40.6782
# WEATHER_LON=-73.9442

# --- LLM (Ollama) ---
# Defaults to the compose network address + qwen2.5:7b. See SETUP.md's
# "Choosing an LLM" section for why, and what to pick for a different GPU.
# OLLAMA_URL=http://ollama:11434/api/chat
# OLLAMA_MODEL=qwen2.5:7b

# --- TTS (Kokoro, GPU profile only — both have defaults) ---
# KOKORO_URL=http://kokoro:8880
# TTS_VOICE=af_bella

# --- Home Assistant integration (optional) ---
# Only needed if you want the chat assistant to control lights via
# Home Assistant (list_lights/control_light tools in chatContext.ts).
# HOMEASSISTANT_URL=http://homeassistant:8123
# HOMEASSISTANT_TOKEN=

# --- Google Calendar integration (optional) ---
# Only needed for the add_calendar_event/get_calendar chat tools to read or
# write to a real Google Calendar. Without GOOGLE_REFRESH_TOKEN, calendar
# writes are disabled gracefully (see api/src/lib/calendar.ts).
# GCP_CLIENT_ID=
# GCP_CLIENT_SECRET=
# GOOGLE_REFRESH_TOKEN=

# --- MindBody booking automation (optional) ---
# Only needed if you use web-agents' book-yoga/book-tabata endpoints.
# MINDBODY_USERNAME=
# MINDBODY_PASSWORD=

# --- Deploy ---
# user@host for `npm run deploy:remote` (ssh's here, then runs deploy.sh).
# SSH_IP=

# --- Observability (Loki/Promtail/Grafana) — Tailscale-only, no CF Access ---
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=
# GRAFANA_URL=http://<tailscale-ip>:3030
